#!perl
use Cassandane::Tiny;

sub test_calendarevent_set_htmldescription
    :min_version_3_1
    ($self)
{
    my $jmap = $self->default_user->jmap;
    my $default_cal_id = $self->default_user->calendars->default->id;

    my $calid = $self->default_user->calendars->default->id;
    my $event =  {
        calendarIds => {
            $calid => JSON::true,
        },
        "uid" => "58ADE31-custom-UID",
        "title"=> "foo",
        "start"=> "2015-11-07T09:00:00",
        "duration"=> "PT5M",
        "sequence"=> 42,
        "timeZone"=> "Etc/UTC",
        "showWithoutTime"=> JSON::false,
        "description"=> '<html><body>HTML with special chars : and ; and "</body></html>',
        "descriptionContentType" => 'text/html',
        "privacy" => "secret",
    };

    my $res = $jmap->CallMethods([
        ['CalendarEvent/set', {
            create => { "1" => $event, }
        }, "R1"],
        ['CalendarEvent/get', { ids => ['#1'] }, 'R2'],
    ]);
    $self->assert_str_equals($event->{description}, $res->[1][1]{list}[0]{description});
    $self->assert_str_equals($event->{descriptionContentType}, $res->[1][1]{list}[0]{descriptionContentType});
}
