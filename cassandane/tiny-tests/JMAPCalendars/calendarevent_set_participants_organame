#!perl
use Cassandane::Tiny;

sub test_calendarevent_set_participants_organame
    :min_version_3_4
    ($self)
{
    my $jmap = $self->default_user->jmap;
    my $default_cal_id = $self->default_user->calendars->default->id;

    my $calid = $self->default_user->calendars->default->id;

    my $event =  {
        calendarIds => {
            $calid => JSON::true,
        },
        "title"=> "title",
        "description"=> "description",
        "start"=> "2015-11-07T09:00:00",
        "duration"=> "PT1H",
        "timeZone" => "Europe/London",
        "showWithoutTime"=> JSON::false,
        "freeBusyStatus"=> "busy",
        "status" => "confirmed",
        "organizerCalendarAddress" => "mailto:foo\@local",
        "participants" => {
            'foo' => {
                '@type' => 'Participant',
                name => 'Foo',
                roles => {
                    'owner' => JSON::true,
                },
                calendarAddress => 'mailto:foo@local',
            },
            'bar' => {
                '@type' => 'Participant',
                name => 'Bar',
                kind => 'individual',
                roles => {
                    'attendee' => JSON::true,
                },
                calendarAddress => 'mailto:bar@local',
            },
        },
    };

    my $ret = $self->createandget_event($event);
    $event->{participants}{bar}{calendarAddress} = 'mailto:bar@local';
    $self->assert_normalized_event_equals($event, $ret);
}
