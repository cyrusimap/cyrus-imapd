#!perl
use Cassandane::Tiny;

sub test_mailbox_changes_create_delete
    :min_version_3_5 :NoAltNameSpace
    ($self)
{
    my $user = $self->default_user;
    my $jmap = $user->jmap;

    $user->mailboxes->create;

    my $res = $jmap->CallMethods([
        ['Mailbox/get', { }, 'R1'],
    ]);
    my $state = $res->[0][1]{state};
    $self->assert_not_null($state);

    $user->mailboxes->create;

    $res = $jmap->CallMethods([
        ['Mailbox/changes', {
            sinceState => $state,
        }, 'R1'],
    ]);
    $state = $res->[0][1]{newState};
    $self->assert_not_null($state);

    my $doomed = $user->mailboxes->create;
    $doomed->destroy;

    $res = $jmap->CallMethods([
        ['Mailbox/changes', {
            sinceState => $state,
        }, 'R1'],
    ]);
    $self->assert_deep_equals([], $res->[0][1]{created});
    $self->assert_deep_equals([], $res->[0][1]{updated});
    $self->assert_deep_equals([], $res->[0][1]{destroyed});
}
