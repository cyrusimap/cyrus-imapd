#!perl
use Cassandane::Tiny;

#
# Test that EMAILID is preserved when copying messages within
# the same account (same ACCOUNTID)
#
sub test_objectidplus_emailid_preserved_on_copy
    :AltNamespace :Conversations :min_version_3_1
{
    my ($self) = @_;

    my $talk = $self->{store}->get_client();

    $talk->create('target');

    $self->make_message("Test message A");
    $self->make_message("Test message B");

    $talk->select('INBOX');

    # get EMAILIDs before copy
    my $fetch_before = $talk->fetch('1:2', '(emailid)');
    my $emailid1 = $fetch_before->{1}{emailid}[0];
    my $emailid2 = $fetch_before->{2}{emailid}[0];
    $self->assert_not_null($emailid1);
    $self->assert_not_null($emailid2);

    # copy message 1 to target
    $talk->copy('1', 'target');
    $self->assert_str_equals('ok', $talk->get_last_completion_response());

    # check EMAILID is preserved in the copy
    $talk->select('target');
    my $fetch_after = $talk->fetch('1', '(emailid)');
    $self->assert_str_equals($emailid1, $fetch_after->{1}{emailid}[0]);
}
