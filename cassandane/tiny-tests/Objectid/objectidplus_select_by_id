#!perl
use Cassandane::Tiny;

#
# Test SELECT by OBJECTID (MAILBOXID id ACCOUNTID id) - ID-based
# mailbox selection after rename
#
sub test_objectidplus_select_by_id
    :AltNamespace :Conversations :min_version_3_1
{
    my ($self) = @_;

    my $talk = $self->{store}->get_client();

    $talk->create('original');
    $self->assert_str_equals('ok', $talk->get_last_completion_response());

    # get the MAILBOXID
    my $status = $talk->status('original', "(mailboxid)");
    my $mailboxid = $status->{mailboxid}[0];
    $self->assert_not_null($mailboxid);

    # rename the mailbox
    $talk->rename('original', 'renamed');
    $self->assert_str_equals('ok', $talk->get_last_completion_response());

    # select by the old name with OBJECTID (MAILBOXID id ACCOUNTID id)
    # should find the renamed mailbox by its MAILBOXID
    $talk->select('original',
        "(OBJECTID (MAILBOXID $mailboxid ACCOUNTID cassandane))");
    $self->assert_str_equals('ok', $talk->get_last_completion_response());

    # verify the selected mailbox has the right MAILBOXID
    my $status2 = $talk->status('renamed', "(mailboxid)");
    $self->assert_str_equals($mailboxid, $status2->{mailboxid}[0]);
}
